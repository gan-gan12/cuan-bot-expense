{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    }
  ],
  "functions": {
    "app.py": {
      "memory": 3009,
      "maxDuration": 60,
      "excludeFiles": "{.git/**,.venv/**,data/**,__pycache__/**,**/*.db,**/*.sqlite,**/*.sqlite3}"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ]
}